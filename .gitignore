# --- Ferramentas portáteis (LilyPond + FluidSynth) ---
# ~130 MB de binários; cada dev baixa pelos links no README.
tools/

# --- Soundfonts (.sf2/.sf3/.sfz) — binários grandes / assets de terceiros ---
# Não versionados por tamanho/licença. O catálogo (soundfonts/README.md)
# diz onde reobter cada um. O README é versionado; os binários não.
soundfonts/*.sf2
soundfonts/*.sf3
soundfonts/*.sfz
soundfonts/samples/
!soundfonts/README.md

# --- Assets GERADOS a partir das fontes (.ly / .py) ---
# Reproduzíveis com render.ps1 a qualquer momento; versionamos só as FONTES.
*.mid
*.mp3
*.pdf
*.png
*.wav

# --- Anotações locais ---
*.local.md
